# ─── Environment ────────────────────────────────────────────────
NODE_ENV=development

# ─── Supabase (Postgres + Auth + Storage) ───────────────────────
# Local defaults from `supabase start`. Print new keys with `supabase status`.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # server-only, never ship to client
SUPABASE_JWT_SECRET=         # used by @sab/api to verify auth tokens

# ─── Direct Postgres (Supabase's local instance — see docs/adr/0004) ───
# `supabase start` spins up a Postgres on :54322. Our Node services connect
# here directly for Drizzle queries and for applying migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:54322/postgres
DATABASE_URL_MIGRATIONS=postgres://postgres:postgres@localhost:54322/postgres

# ─── Redis (rate limits, queues, feed cache) ────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meilisearch (beer / brewery search, UC-3 / UC-14) ──────────
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=dev-master-key-change-me

# ─── Media storage (Cloudflare R2) ──────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=shareabeer-media
R2_PUBLIC_BASE_URL=

# ─── Video transcoding (Mux) ────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# ─── Anthropic (Claude Sonnet 4.6 vision — UC-2 recognition) ────
ANTHROPIC_API_KEY=
ANTHROPIC_RECOGNITION_MODEL=claude-sonnet-4-6

# ─── Age verification (Veriff primary, Yoti fallback) ───────────
VERIFF_API_KEY=
VERIFF_PRIVATE_KEY=
VERIFF_WEBHOOK_SECRET=

# ─── Push notifications (Expo) ──────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─── Observability ──────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ─── API service ────────────────────────────────────────────────
API_PORT=4000
API_JWT_ISSUER=https://shareabeer.app
API_PUBLIC_URL=http://localhost:4000
RECOGNITION_URL=http://localhost:4010

# ─── Mobile (public-prefixed only; never put secrets here) ──────
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_SENTRY_DSN=
