{
  "name": "share-a-beer",
  "version": "0.0.0",
  "private": true,
  "description": "Share a Beer — cross-platform social mobile app for beer lovers",
  "author": "Danny Mairena <dannymairena01@gmail.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.18.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "dev:api": "pnpm --filter @sab/api dev",
    "dev:recognition": "pnpm --filter @sab/recognition dev",
    "dev:mobile": "pnpm --filter @sab/mobile start",
    "dev:admin": "pnpm --filter @sab/admin dev",
    "dev:infra": "docker compose -f infra/docker/docker-compose.yml up -d",
    "db:generate": "pnpm --filter @sab/db generate",
    "db:migrate": "pnpm --filter @sab/db migrate",
    "db:studio": "pnpm --filter @sab/db studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1",
      "@types/react": "~18.3.12",
      "@types/react-dom": "~18.3.1"
    }
  }
}
