# pnpm's default isolated linker uses symlinks into .pnpm/; Metro and several
# React Native tools don't follow those reliably, which breaks Expo bundling
# for even simple transitive deps (e.g. @expo/metro-runtime → whatwg-fetch).
# Expo's monorepo guide recommends the hoisted linker for pnpm + RN projects.
node-linker=hoisted

# Keep the lockfile strictly honored in CI.
frozen-lockfile=true
